{
  "name": "aimer-live-cd-app",
  "version": "1.0.0",
  "description": "Aimer Live CD Music App",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "phamngocduy98.github.io",
  "homepage": "https://music.btxa.io.vn",
  "scripts": {
    "passgen": "node --no-warnings=ExperimentalWarning --loader ts-node/esm src/main/backend/passgen.ts",
    "cleanup:album-refs": "node --no-warnings=ExperimentalWarning --loader ts-node/esm src/main/backend/scripts/cleanupAlbumRefs.ts",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:server": "tsx src/main/backend/standalone.ts",
    "dev:web": "vite --config src/renderer/vite.config.ts",
    "dev:both": "concurrently -n server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "@mui/icons-material": "^5.11.0",
    "@mui/material": "^5.16.7",
    "@reduxjs/toolkit": "^2.2.7",
    "@tanstack/react-pacer": "^0.22.1",
    "@types/lodash.assign": "^4.2.9",
    "aes-encrypt-stream": "^0.2.0",
    "axios": "^1.2.2",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.3.9",
    "express": "^4.18.2",
    "ftp": "^0.3.10",
    "get-port": "^7.1.0",
    "linkedlist": "^1.0.1",
    "localforage": "^1.10.0",
    "lodash.assign": "^4.2.0",
    "lru-cache": "^11.0.2",
    "match-sorter": "^6.3.1",
    "mongodb": "^4.12.1",
    "mongoose": "^6.8.0",
    "multer": "^1.4.5-lts.1",
    "multistream": "^4.1.0",
    "music-metadata": "10.2.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "react-player": "^2.16.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.6.2",
    "react-use-audio-player": "^2.2.0",
    "sort-by": "^1.2.0",
    "streaming-cache": "^0.5.5",
    "webdav-server": "^2.6.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/ftp": "^0.3.36",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "prettier": "^3.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.5"
  }
}
