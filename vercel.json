{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm typecheck:backend && pnpm typecheck:vercel && pnpm typecheck:web && pnpm build:web",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
